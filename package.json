{
  "name": "loungestarter",
  "version": "1.0.1",
  "description": "A lightweight Windows desktop app to manage which applications launch at startup",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis",
    "dist:all": "electron-builder --win nsis portable",
    "release": "electron-builder --win --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.loungestarter.app",
    "productName": "LoungeStarter",
    "copyright": "Copyright © 2026 LoungeStarter",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LoungeStarter",
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "deleteAppDataOnUninstall": false,
      "installerHeaderIcon": "assets/icons/icon.ico"
    },
    "portable": {
      "artifactName": "LoungeStarter-Portable-${version}.exe"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "extraMetadata": {
      "main": "src/main.js"
    }
  },
  "keywords": [
    "startup",
    "launcher",
    "electron",
    "windows",
    "startup-manager"
  ],
  "author": "LoungeStarter",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0"
  }
}
